# WritSpace Environment Configuration
# Copy this file to .env and fill in your values

# PostgreSQL connection string (Neon serverless PostgreSQL)
# Format: postgresql://<user>:<password>@<host>/<database>?sslmode=require
# sslmode=require is mandatory for Neon connections
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/writespace?sslmode=require

# Secret key used for signing and verifying JWT authentication tokens
# Use a strong, random string of at least 32 characters
# Generate one with: openssl rand -base64 64
JWT_SECRET=your-secret-key-change-me-in-production

# Default admin account credentials
# These are used to seed the initial admin user on first startup
# Change these values before deploying to production
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-in-production

# Rust logging configuration
# Controls log verbosity for the application and dependencies
# Examples:
#   info                  - info level for all modules
#   writespace=debug      - debug level for app, default for others
#   tower_http=debug      - include HTTP request/response tracing
#   sqlx=warn             - reduce sqlx noise
#   writespace=debug,tower_http=debug,sqlx=warn - combined
RUST_LOG=writespace=info,tower_http=debug